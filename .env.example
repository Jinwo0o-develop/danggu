# ── 앱 설정 ───────────────────────────────────────────────────────────────────
# "production" 으로 변경하면 HSTS 활성화 (Vercel 배포 시 반드시 설정)
APP_ENV=development

# 세션 서명 키 — 아래 명령으로 생성:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ⚠️ 절대 기본값 그대로 사용하지 마십시오. Vercel 환경변수에 반드시 등록하세요.
SECRET_KEY=your-random-secret-key-here

# ── 어드민 설정 ───────────────────────────────────────────────────────────────
# 어드민 계정 생성 시 사용하는 등록 키 (비워 두면 등록 비활성화)
# Vercel 첫 배포 후 /admin/register 에서 이 키로 최초 관리자 계정을 생성하세요.
ADMIN_REGISTER_KEY=your-admin-register-key-here

# ── Vercel 자동 주입 (직접 설정 불필요) ──────────────────────────────────────
# VERCEL=1  →  데이터 저장 경로를 /tmp/data 로 자동 전환
#              (Vercel 서버리스 환경에서 /var/task/ 는 읽기 전용)
